{
  "compilerOptions": {
    "target": "es6",
    "module": "esnext",
    "lib": ["ES2020", "DOM"],
    "moduleResolution": "node",
    "baseUrl": ".",
    "paths": {
      "@api/*": ["src/api/*"],
      "@/*": ["src/*"]
    },
    "outDir": "./dist",
    "rootDir": "./", // Garante que a estrutura de pastas (como 'src') é mantida no 'dist'
    "strict": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "esModuleInterop": true
  },
  "include": ["src/**/*", "main.ts", "src/tasks"],
  "exclude": ["node_modules", "dist", "testes"]
}
