{
  "name": "m3_mini_projeto",
  "version": "1.0.0",
  "description": "Gestão de utilizadores e tarefas",
  "license": "ISC",
  "author": "Danilson Sanches",
  "type": "module",
  "main": "dist/main.js",
  "scripts": {
    "build": "tsc && npm run copy:assets",
    "copy:assets": "copyfiles -u 0 \"src/assets/**/*\" \"src/styles/**/*\" dist",
    "watch": "tsc -w",
    "start": "npm run build",
    "test": "vitest",
    "test:watch": "vitest --watch",
    "test:ci": "vitest --run"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "copyfiles": "^2.4.1",
    "jsdom": "^29.0.1",
    "shx": "^0.4.0",
    "vitest": "^4.1.2"
  }
}
